# Shared automation environment.
# Copy to automation/.env or export these variables in your shell.

# Paper Easy MCP authentication. Use the same value as paper-easy/.env.
PAPERS_EASY_ADMIN_TOKEN=

# Zotero local API, provided by Zotero Desktop.
ZOTERO_LOCAL_BASE_URL=http://127.0.0.1:23119

# Obsidian output location used by 04_daily_paper_brief.py when --output is omitted.
OBSIDIAN_VAULT=~/Obsidian
OBSIDIAN_DAILY_PAPERS_DIR=DailyPapers

# Optional override when codex is not on PATH.
CODEX_BIN=codex

